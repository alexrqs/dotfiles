brew "bat"
brew "ripgrep"
brew "fd"
brew "neovim"
brew "lazygit"
brew "gnu-sed"
brew "nvm"
brew "oven-sh/bun/bun"
brew "jq"
brew "xh"
brew "git-delta"
brew "mosh"
brew "terminal-notifier"
brew "uv"
brew "fileicon"

