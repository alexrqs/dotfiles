# Ghostty config. Mirrors the kitty setup: a regular monospace primary
# with Symbols Nerd Font Mono as a glyph-fallback for icons.
#
# In ghostty, multiple `font-family` lines cascade — the FIRST line is
# the primary font (used for text), subsequent lines are fallbacks for
# glyphs the primary doesn't have. Earlier this file only had the
# Symbols Nerd Font Mono line, which has no letters/numbers, so text
# rendering was broken (huge inter-character spacing).

font-size = 18

# Primary monospace font (matches kitty's default on macOS).
font-family = Menlo

# Fallback for Nerd Font icon glyphs (Powerline, Codicons, Devicons, etc.).
font-family = Symbols Nerd Font Mono
