lz() { nvim "${1:-.}"; }

yolo() {
  local current_branch
  current_branch=$(git branch --show-current)

  echo "🚀 YOLO-ing changes..."
  git add . || return 1

  # Conventional + gitflow prefixes that earn a ticket-style commit subject.
  # Anything else (including main/master) commits with the raw message.
  local prefixes='(feat|feature|fix|bugfix|hotfix|chore|refactor|docs|test|perf|style|build|ci|revert)'

  local subject
  if [[ "${current_branch:l}" =~ ^${prefixes}/([a-zA-Z]+)-([0-9]+) ]]; then
    local type="${match[1]}"
    local project="${match[2]:u}"
    local ticket="${match[3]}"
    if [[ $# -gt 0 ]]; then
      subject="[${project}-${ticket}] ${type}: $*"
    else
      local changed
      changed=$(git diff --cached --name-only | paste -sd ',' - | sed 's/,/, /g')
      subject="[${project}-${ticket}] ${type}: ${changed}"
    fi
  else
    if [[ $# -gt 0 ]]; then
      subject="$*"
    else
      local changed
      changed=$(git diff --cached --name-only | paste -sd ',' - | sed 's/,/, /g')
      subject="changes: ${changed}"
    fi
  fi

  git commit -m "$subject" && git push --force-with-lease
}
