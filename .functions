#!/bin/bash

# Auto-list directory stack after cd
chpwd() {
  ls -a
  # dirs -v | head -10
  if git rev-parse --git-dir >/dev/null 2>&1; then
    gss
  fi

  auto-switch-nvmrc
}

# cd into whatever is the forefront Finder window.
# only mac
cdf() { # short for cdfinder
  cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')"
}

# Copy w/ progress (uses rsync's -P for partial+progress).
#
# Examples:
#   cp_p big.iso ~/Downloads/        # single file → dir
#   cp_p src/ dest/                  # contents of src/ into dest/  (trailing slash matters)
#   cp_p src  dest                   # creates dest/src             (no trailing slash on source)
cp_p() {
  rsync -WavP --human-readable --progress "$1" "$2"
}

# Show useful network info: public IP, local IPs per interface,
# default gateway, DNS resolvers. macOS-only (uses networksetup,
# ipconfig, route, scutil).
ip() {
  echo "🌐 Public IP:"
  dig +short +time=2 +tries=1 myip.opendns.com @resolver1.opendns.com | sed 's/^/  /'

  echo
  echo "🏠 Local IPs:"
  local hw dev addr
  while IFS= read -r line; do
    case "$line" in
    "Hardware Port: "*) hw="${line#Hardware Port: }" ;;
    "Device: "*)
      dev="${line#Device: }"
      addr=$(ipconfig getifaddr "$dev" 2>/dev/null)
      [ -n "$addr" ] && printf "  %-20s %-8s %s\n" "$hw" "$dev" "$addr"
      ;;
    esac
  done < <(networksetup -listallhardwareports)

  echo
  echo "🚪 Gateway:"
  route -n get default 2>/dev/null | awk '/gateway:/ {print "  " $2}'

  echo
  echo "🧭 DNS:"
  scutil --dns | awk '/nameserver\[0\]/ {print $3}' | sort -u | sed 's/^/  /'
}

# direct it all to /dev/null
function nullify() {
  "$@" >/dev/null 2>&1
}

function killport() {
  local pids
  pids=$(lsof -ti ":$1")
  if [ -z "$pids" ]; then
    echo "nothing listening on port $1"
    return 1
  fi
  echo "killing $(echo "$pids" | wc -l | tr -d ' ') process(es) on port $1: $pids"
  echo "$pids" | xargs kill
}

function refresh() {
  bunx rimraf build/ dist/ node_modules/ .next/

  if [[ $1 == 'bun' ]]; then
    bun install
  else
    npm install
  fi
}

# function klogs() {
#   kl --tail 1 $(kgp | grep $1 | awk '{ print $1 }')
# }   # kubectl stack not installed

function auto-switch-nvmrc() {
  local dir="$PWD"

  # Fast path: still inside the .nvmrc tree we already activated.
  # Skips the walk-up + nvm calls when cd'ing deeper into the same project.
  if [ -n "$_CURRENT_NVMRC" ]; then
    local project_root="${_CURRENT_NVMRC%/.nvmrc}"
    case "$dir" in
      "$project_root"|"$project_root"/*) return ;;
    esac
  fi

  local nvmrc_path=""
  while [ "$dir" != "" ]; do
    if [ -f "$dir/.nvmrc" ]; then
      nvmrc_path="$dir/.nvmrc"
      break
    fi
    dir="${dir%/*}"
  done

  if [ -z "$nvmrc_path" ]; then
    if [ -n "$_CURRENT_NVMRC" ]; then
      _CURRENT_NVMRC=""
      nvm use default
    fi
    return
  fi

  [ "$nvmrc_path" = "$_CURRENT_NVMRC" ] && return
  _CURRENT_NVMRC="$nvmrc_path"

  # $(<file) is a zsh builtin file-read — no fork/exec, unlike $(cat).
  local desired="$(<$nvmrc_path)"
  local current="$(nvm version)"
  local resolved="$(nvm version "$desired")"

  if [ "$resolved" = "N/A" ]; then
    nvm install
  elif [ "$resolved" != "$current" ]; then
    nvm use
  fi
}

