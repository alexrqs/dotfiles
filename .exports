
# nvim is the underlying editor; `lz` is a shell function, which
# subprocesses can't exec, so $EDITOR has to point at the real binary.
export EDITOR="nvim"

# Don’t clear the screen after quitting a manual page
export MANPAGER="less -X"

# Prefer US English and use UTF-8
export LC_ALL="en_US.UTF-8"
export LANG="en_US"
